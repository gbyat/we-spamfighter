#. translators: %d: Number of log entries
#: includes/admin/class-settings.php:1265
#, php-format
msgid "Currently %d entries in the activity log."
msgstr "Derzeit %d Einträge im Aktivitätsprotokoll."

#: includes/admin/class-settings.php:1273
#: includes/admin/class-settings.php:1341
msgid "Are you sure you want to clear the activity log? This action cannot be undone."
msgstr "Sicher, dass du die Nachricht löschen möchtest? - Die Aktion kann nicht rückgängig gemacht werden."

#: includes/admin/class-settings.php:1274
#: includes/admin/class-settings.php:1342
msgid "Clear Activity Log"
msgstr "Aktivitätsprotokoll löschen"

#: includes/admin/class-settings.php:1302
msgid "Activity Log is not enabled. Please enable it in Settings → Maintenance tab."
msgstr "Das Aktivitätsprotokoll ist nicht aktiviert. Bitte aktivieren Sie es unter „Einstellungen“ → Registerkarte „Wartung“."

