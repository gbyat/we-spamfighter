msgid "Activity Log"
msgstr "Aktivitätsprotokoll"

#: includes/admin/class-settings.php:167
msgid "General Settings"
msgstr "Allgemeine Einstellungen"

#: includes/admin/class-settings.php:174
msgid "Enable Contact Form 7 Protection"
msgstr "Contact Form 7-Schutz aktivieren"

#: includes/admin/class-settings.php:180
msgid "Enable spam protection for Contact Form 7 submissions"
msgstr "Spam-Schutz für Contact Form 7-Übermittlungen aktivieren"

#: includes/admin/class-settings.php:186
msgid "Enable Comments Protection"
msgstr "Kommentare schützen"

#: includes/admin/class-settings.php:192
msgid "Enable spam protection for comments"
msgstr "Spamschutz für Kommentare aktivieren"

#: includes/admin/class-settings.php:198
msgid "Automatically Mark Pingbacks/Trackbacks as Spam"
msgstr "Pingback/Trackback automatisch als Spam markieren"

#: includes/admin/class-settings.php:204
msgid "Automatically mark pingbacks and trackbacks as spam without OpenAI check"
msgstr "Pingbacks und Trackbacks automatisch als Spam markieren, ohne OpenAI-Prüfung"

#: includes/admin/class-settings.php:211
msgid "Mark Different Language as Spam"
msgstr "Andere Sprache als Spam markieren"

#: includes/admin/class-settings.php:217
msgid "Automatically mark submissions as spam if free-text content appears to be in a different language than your website. Name, email, phone, salutation, birth date, and similar fields are ignored so foreign names alone do not trigger this."
msgstr "Markieren Sie Eingaben automatisch als Spam, wenn der Freitextinhalt offenbar in einer anderen Sprache verfasst ist als Ihre Website. Felder wie Name, E-Mail-Adresse, Telefonnummer, Anrede, Geburtsdatum und ähnliche werden ignoriert, sodass ausländische Namen allein diese Funktion nicht auslösen."

#: includes/admin/class-settings.php:223
msgid "Language Mismatch Score Boost"
msgstr "Sprachinkongruenz-Score-Boost"

#: includes/admin/class-settings.php:232
msgid "Amount to increase spam score when language doesn't match (0.1 - 1.0). Default: 0.3"
msgstr "Betrag zur Erhöhung der Spam-Bewertung, wenn die Sprache nicht übereinstimmt (0,1 – 1,0). Standardwert: 0,3"

#: includes/admin/class-settings.php:238
msgid "Spam Blocked Message"
msgstr "Nachricht nach Übermittlung eines Spams"

#: includes/admin/class-settings.php:245
msgid "Message displayed to users when spam is detected and submission is blocked. Default: \"Thank you for your message.\""
msgstr "Meldung, die Benutzern angezeigt wird, wenn Spam erkannt und die Übermittlung blockiert wird. Standard: „Vielen Dank für Ihre Nachricht.“"

#: includes/admin/class-settings.php:307
msgid "OpenAI API Key"
msgstr "OpenAI API-Schlüssel"

#: includes/admin/class-settings.php:324
msgid "OpenAI Model"
msgstr "OpenAI-Modell"

#: includes/admin/class-settings.php:344
msgid "AI Spam Threshold"
msgstr "KI-Spam-Schwellenwert"

#: includes/admin/class-settings.php:353
msgid "Spam score threshold (0.0 - 1.0). Higher values mean fewer submissions are flagged as spam (less strict). Lower values mean more submissions are flagged as spam (more strict). Default: 0.7"
msgstr "Spam-Score-Schwellenwert (0,0 – 1,0). Höhere Werte bedeuten, dass weniger Beiträge als Spam markiert werden (weniger streng). Niedrigere Werte bedeuten, dass mehr Beiträge als Spam markiert werden (strenger). Standardwert: 0,7"

#: includes/admin/class-settings.php:360
#: includes/admin/class-settings.php:1127
msgid "Heuristic Detection"
msgstr "Heuristische Erkennung"

#: includes/admin/class-settings.php:367
msgid "Enable Heuristic Detection"
msgstr "Heuristische Erkennung aktivieren"

#: includes/admin/class-settings.php:373
msgid "Use local heuristics to detect spam patterns (works without OpenAI)"
msgstr "Verwenden Sie lokale Heuristiken, um Spam-Muster zu erkennen (funktioniert ohne OpenAI)."

#: includes/admin/class-settings.php:379
msgid "Heuristic Spam Threshold"
msgstr "Heuristik-Spam-Schwellenwert"

#: includes/admin/class-settings.php:388
msgid "Spam score threshold for heuristic detection (0.0 - 1.0). Default: 0.6"
msgstr "Spam-Score-Schwellenwert für heuristische Erkennung (0,0 – 1,0). Höher = strenger. Standardwert: 0,7"

#: includes/admin/class-settings.php:394
msgid "Enable Link Check"
msgstr "Link-Prüfung aktivieren"

#: includes/admin/class-settings.php:400
msgid "Enable suspicious link detection"
msgstr "Erkennung verdächtiger Links aktivieren"

#: includes/admin/class-settings.php:406
msgid "Enable Character Pattern Check"
msgstr "Zeichenmusterprüfung aktivieren"

#: includes/admin/class-settings.php:412
msgid "Enable suspicious character pattern detection (e.g., ALL CAPS, repeated characters)"
msgstr "Aktivieren Sie die Erkennung verdächtiger Zeichenmuster (z. B. alles in GROSSBUCHSTABEN, wiederholte Zeichen)."

#: includes/admin/class-settings.php:418
msgid "Enable Spam Phrase Check"
msgstr "Spam-Phrasenprüfung aktivieren"

#: includes/admin/class-settings.php:424
msgid "Enable known spam phrase detection"
msgstr "Erkennung von Spam-Phrasen aktivieren"

#: includes/admin/class-settings.php:430
msgid "Enable Email Pattern Check"
msgstr "E-Mail-Musterprüfung aktivieren"

#: includes/admin/class-settings.php:436
msgid "Enable suspicious email pattern detection"
msgstr "Erkennung verdächtiger E-Mail-Muster aktivieren"

#: includes/admin/class-settings.php:442
msgid "Enable Referrer Check"
msgstr "Referrer Prüfung aktivieren"

#: includes/admin/class-settings.php:448
msgid "Enable referrer analysis (missing or suspicious referrer detection)"
msgstr "Referrer-Analyse aktivieren (Erkennung fehlender oder verdächtiger Referrer)"

#: includes/admin/class-settings.php:454
msgid "Enable User Agent Check"
msgstr "User-Agent Prüfung aktivieren"

#: includes/admin/class-settings.php:460
msgid "Enable user agent analysis (bot and suspicious user agent detection)"
msgstr "User Agent Analyse aktivieren (Bots und verdächtige User Agents erkennen)"

#: includes/admin/class-settings.php:466
msgid "Enable Content Length Check"
msgstr "Inhaltslängenprüfung aktivieren"

#: includes/admin/class-settings.php:472
msgid "Enable content length analysis (very short or extremely long content detection)"
msgstr "Prüfung der Inhaltslänge aktivieren (sehr kurzer oder extrem langer Inhalt)"

#: includes/admin/class-settings.php:526
msgid "Enable Mixed Script Check"
msgstr "Gemischte Zeichensatzprüfung aktivieren"

#: includes/admin/class-settings.php:532
msgid "Enable mixed script detection (different character sets like Cyrillic + Latin)"
msgstr "Aktivieren Sie die Erkennung gemischter Zeichensätze (unterschiedliche Zeichensätze wie Kyrillisch + Lateinisch)."

#: includes/admin/class-settings.php:538
msgid "Enable Unicode Anomalies Check"
msgstr "Zeichensatz-Anomalieprüfung aktivieren"

#: includes/admin/class-settings.php:544
msgid "Enable Unicode anomalies detection (zero-width characters, control characters, homoglyphs)"
msgstr "Unicode-Anomalienerkennung aktivieren (Zeichen ohne Breite, Steuerzeichen, Homoglyphen)"

#: includes/admin/class-settings.php:550
msgid "Enable Numbers/Letters Only Check"
msgstr "Nur Nummern-/Buchstabenprüfung aktivieren"

#: includes/admin/class-settings.php:556
msgid "Enable detection of content containing only numbers or only letters"
msgstr "Erkennung von Inhalten, die nur Zahlen oder nur Buchstaben enthalten, aktivieren"

#: includes/admin/class-settings.php:562
msgid "Enable IP Address in Content Check"
msgstr "Prüfung auf IP-Adressen im Inhalt aktivieren"

#: includes/admin/class-settings.php:568
msgid "Enable detection of IP addresses in content (not in URLs)"
msgstr "Erkennung von IP-Adressen in Inhalten (nicht in URLs) aktivieren"

#: includes/admin/class-settings.php:574
msgid "Enable Repeated Multilingual Content Check"
msgstr "Prüfung auf IP-Adressen im Inhalt aktivieren"

#: includes/admin/class-settings.php:580
msgid "Enable detection of repeated multilingual content (same message in multiple languages separated by markers like ***)"
msgstr "Erkennung von wiederholten mehrsprachigen Inhalten aktivieren (gleiche Nachricht in mehreren Sprachen, getrennt durch Markierungen wie ***)"

#: includes/admin/class-settings.php:587
msgid "Email Notifications"
msgstr "E-Mail Benachrichtigungen"

#: includes/admin/class-settings.php:594
msgid "Notification Email"
msgstr "Benachrichtigungsemail"

#: includes/admin/class-settings.php:601
msgid "Email address to receive spam notifications. If empty, admin email will be used."
msgstr "E-Mail-Adresse für den Empfang von Spam-Benachrichtigungen. Wenn dieses Feld leer ist, wird die E-Mail-Adresse des Administrators verwendet."

#: includes/admin/class-settings.php:607
msgid "Notification Type"
msgstr "Benachrichtigungsart"

#: includes/admin/class-settings.php:614
msgid "No notifications"
msgstr "Keine Benachrichtigungen"

#: includes/admin/class-settings.php:615
msgid "Immediate (on each spam detection)"
msgstr "Sofort (bei jeder Spam-Erkennung)"

#: includes/admin/class-settings.php:616
msgid "Daily summary"
msgstr "Tägliche Zusammenfassung"

#: includes/admin/class-settings.php:617
msgid "Weekly summary"
msgstr "Wöchentliche Zusammenfassung"

#: includes/admin/class-settings.php:619
msgid "How often to receive spam notifications."
msgstr "Wie oft Spam-Benachrichtigungen empfangen werden sollen."

#: includes/admin/class-settings.php:626
#: includes/admin/class-settings.php:1139
msgid "Maintenance"
msgstr "Wartung"

#: includes/admin/class-settings.php:633
msgid "Log Retention"
msgstr "Dauer der Protokollspeicherung"

#: includes/admin/class-settings.php:642
msgid "Days to keep logs (default: 30)"
msgstr "Tage, an denen Protokolle aufbewahrt werden (Standard: 30)"

#: includes/admin/class-settings.php:648
msgid "Keep Data on Uninstall"
msgstr "Daten bei Deinstallation behalten"

#: includes/admin/class-settings.php:654
msgid "If enabled, all plugin data (options, submissions, statistics) will be kept when the plugin is deleted. If disabled, all data will be permanently deleted."
msgstr "Wenn diese Option aktiviert ist, bleiben alle Plugin-Daten (Optionen, Übermittlungen, Statistiken) beim Löschen des Plugins erhalten. Wenn diese Option deaktiviert ist, werden alle Daten dauerhaft gelöscht."

#: includes/admin/class-settings.php:660
msgid "Enable GitHub Updates"
msgstr "Updates via Github aktivieren"

#: includes/admin/class-settings.php:666
msgid "Enable automatic updates from GitHub releases. <strong>Activate at your own risk.</strong> Updates will be installed automatically without additional confirmation."
msgstr "Aktivieren Sie automatische Updates aus GitHub-Releases. <strong>Die Aktivierung erfolgt auf eigene Gefahr.</strong> Updates werden automatisch und ohne zusätzliche Bestätigung installiert."

#: includes/admin/class-settings.php:672
msgid "Enable Activity Log"
msgstr "Aktivitätsprotokoll aktivieren"

#: includes/admin/class-settings.php:678
msgid "Enable activity logging to track important plugin events (e.g., weekly summaries sent, table maintenance)."
msgstr "Aktivieren Sie die Aktivitätsprotokollierung, um wichtige Plugin-Ereignisse zu verfolgen (z. B. versendete wöchentliche Zusammenfassungen, Tabellenpflege)."

#: includes/admin/class-settings.php:685
msgid "Privacy / GDPR"
msgstr "Privatsphäre / DSGVO"

#: includes/admin/class-settings.php:692
msgid "Privacy passage on privacy policy page"
msgstr "Datenschutzpassage auf der Seite mit den Datenschutzbestimmungen"

#: includes/admin/class-settings.php:699
msgid "Filter: Append automatically to privacy page"
msgstr "Filter: Automatisch an Datenschutzseite anhängen"

#: includes/admin/class-settings.php:700
msgid "Manual: Use shortcode [we_spamfighter_privacy] or block"
msgstr "Manuel: Verwenden Sie den Shortcode [we_spamfighter_privacy] oder Block."

#: includes/admin/class-settings.php:701
msgid "None: Do not add (at your own risk)"
msgstr "Keine: Nicht hinzufügen (auf eigene Gefahr)"

#: includes/admin/class-settings.php:703
msgid "How to include the privacy passage. Only active when OpenAI is enabled."
msgstr "So fügen Sie den Datenschutzhinweis ein. Nur aktiv, wenn OpenAI aktiviert ist."

#: includes/admin/class-settings.php:710
msgid "Form notice"
msgstr "Formular-Hinweis"

#: includes/admin/class-settings.php:716
msgid "Show notice at comment and CF7 forms when OpenAI is active."
msgstr "Zeige Hinweis bei Kommentar und CF7-Formularen, wenn OpenAI aktiv ist."

#: includes/admin/class-settings.php:727
msgid "Configure general spam protection settings."
msgstr "Konfiguriere allgemeine Spam-Schutzeinstellungen."

#: includes/admin/class-settings.php:735
msgid "Privacy-related options for OpenAI usage. These settings only take effect when OpenAI is enabled and an API key is configured."
msgstr "Datenschutzbezogene Optionen für die Nutzung von OpenAI. Diese Einstellungen werden nur wirksam, wenn OpenAI aktiviert und ein API-Schlüssel konfiguriert ist."

#: includes/admin/class-settings.php:850
msgid "Configure local heuristic spam detection (works without OpenAI)."
msgstr "Lokale heuristische Spam-Erkennung konfigurieren (funktioniert ohne OpenAI)."

#: includes/admin/class-settings.php:854
msgid "Enable All Checks"
msgstr "Alle Prüfungen aktivieren"

#: includes/admin/class-settings.php:857
msgid "Disable All Checks"
msgstr "Alle Prüfungen deaktivieren"

#: includes/admin/class-settings.php:896
msgid "Configure email notifications for spam detections."
msgstr "E-Mail-Benachrichtigungen für Spam-Erkennungen."

#: includes/admin/class-settings.php:904
msgid "Configure maintenance and cleanup settings."
msgstr "Einstellungen für Wartung und Bereinigung."

#: includes/admin/class-settings.php:914
msgid "Email Notification Status:"
msgstr "E-Mail Benachrichtigungsstatus:"

#: includes/admin/class-settings.php:927
msgid "Daily summary: NOT SCHEDULED - Please save settings to schedule."
msgstr "Tägliche Zusammenfassung: NICHT GEPLANT – Bitte speichern Sie die Einstellungen, um einen Zeitplan zu erstellen."

#. translators: %s: Next scheduled time
#: includes/admin/class-settings.php:923
#, php-format
msgid "Daily summary: Next scheduled for %s"
msgstr "Tägliche E-Mail-Zusammenfassung geplant für %s"

#: includes/admin/class-settings.php:942
msgid "Weekly summary: NOT SCHEDULED - Please save settings to schedule."
msgstr "Wöchentliche Zusammenfassung: NICHT GEPLANT – Bitte Einstellungen speichern, um zu planen."

#. translators: %s: Next scheduled time
#: includes/admin/class-settings.php:938
#, php-format
msgid "Weekly summary: Next scheduled for %s"
msgstr "Wöchentliche E-Mail-Zusammenfassung: die nächste ist geplant für %s"

#: includes/admin/class-settings.php:950
msgid "WARNING: WordPress cron is disabled. Email notifications will not work unless you use a real cron job."
msgstr "WARNUNG: WordPress Cron ist deaktiviert. E-Mail-Benachrichtigungen funktionieren nur, wenn Sie einen echten Cron-Job verwenden."

#. translators: %s: Email address
#: includes/admin/class-settings.php:957
#, php-format
msgid "Notification email: %s"
msgstr "Benachrichtigungsemail: %s"

#. translators: %s: Link to Activity Log
#: includes/admin/class-settings.php:965
#, php-format
msgid "Check the %s for email delivery logs and debug information."
msgstr "Überprüfen Sie die %s für E-Mail-Zustellungsprotokolle und Debug-Informationen."

#: includes/admin/class-settings.php:1123
msgid "General"
msgstr "Allgemein"

#: includes/admin/class-settings.php:1135
msgid "Notifications"
msgstr "Benachrichtigungen"

#: includes/admin/class-settings.php:1143
msgid "Privacy"
msgstr "Datenschutz"

#: includes/admin/class-settings.php:1156
msgid "WE Spamfighterin Settings"
msgstr "WE Spamfighterin-Einstellungen"

#: includes/admin/class-settings.php:1233
