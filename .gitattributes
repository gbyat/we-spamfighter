# Normalize line endings to LF in the repository.
* text=auto eol=lf

*.php text eol=lf
*.js text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.pot text eol=lf
*.po text eol=lf
*.mo binary
*.l10n.php text eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.zip binary
*.phar binary

*.cmd text eol=crlf
*.bat text eol=crlf
